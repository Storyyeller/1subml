type rec ast[+T] = [
    `Val T |
    `Eq (bool => T, ast[int], ast[int]) |
    `Plus (int => T, ast[int], ast[int]) |
    `If (ast[bool], ast[T], ast[T])
];
let Val = fun[T] x: T :: ast[T] -> ast `Val x;
let Eq = fun (lhs: ast[int], rhs: ast[int]) :: ast[bool] -> ast `Eq (id!, lhs, rhs);
let Plus = fun (lhs: ast[int], rhs: ast[int]) :: ast[int] -> ast `Plus (id!, lhs, rhs);
let If = fun[T] (cond: ast[bool], lhs: ast[T], rhs: ast[T]) :: ast[T] -> ast `If (cond, lhs, rhs);

let rec eval = fun[T] expr: ast[T] :: T -> 
    match expr with 
    | `Val x -> x
    | `Eq (T, lhs, rhs) -> T (eval lhs == eval rhs)
    | `Plus (T, lhs, rhs) -> T (eval lhs + eval rhs)
    | `If (cond, lhs, rhs) -> (if eval cond then eval lhs else eval rhs)
;


type Opt[+T] = [`Some T | `None];
let Some = fun[T] x: T :: Opt[T] -> Opt `Some x;
let None: Opt[never] = Opt `None 0;

type ret[-In; +Out] = [
    `RetNone Opt[In] => Out |
    `Default (In => Out, Out)
];
let RetNone = fun[T] _ :: ret[T;Opt[T]] -> ret `RetNone id!;
let Default = fun[T] x: T :: ret[T;T] -> ret `Default (id!, x);

let find = fun[In; Out] (x: In, style: ret[In; Out]) :: Out -> (
    if true then 
        match style with 
        | `RetNone f -> f Some x 
        | `Default (f, _) -> f x
    else 
        match style with 
        | `RetNone f -> f None 
        | `Default (f, d) -> d 
);


type rec pipe[-In; +Out] = [
    `Step {type Mid; f: In -> Mid; rest: pipe[Mid; Out]} |
    `Empty In => Out 
]; 
let Step = fun[In; Mid; Out] (f: (In -> Mid), rest: pipe[Mid; Out]) :: pipe[In; Out] -> (
    pipe `Step ({f; rest} :> {type Mid; f: In -> Mid; rest: pipe[Mid; Out]})
);
let Empty = fun[T] _ :: pipe[T; T] -> pipe `Empty id!;

let rec run = fun[In; Out] (v: In, fs: pipe[In; Out]) :: Out -> match fs with 
| `Step r -> (
    mod M: {type Mid; f: In -> Mid; rest: pipe[Mid; Out]} = r;
    run (M.f v, M.rest)
)
| `Empty f -> f v 
;
