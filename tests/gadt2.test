type opt[+T] = | Some T | None;

type rec ast[+T] = 
    | Val T 
    | Eq (bool => T, ast[int], ast[int]) 
    | Plus (int => T, ast[int], ast[int]) 
    | If (ast[bool], ast[T], ast[T])
;
let Eq = fun (lhs: ast[int], rhs: ast[int]) :: ast[bool] -> Eq (id!, lhs, rhs);
let Plus = fun (lhs: ast[int], rhs: ast[int]) :: ast[int] -> Plus (id!, lhs, rhs);


let rec eval = fun[T] expr: ast[T] :: T -> 
    match expr with 
    | `Val x -> x
    | `Eq (T, lhs, rhs) -> T (eval lhs == eval rhs)
    | `Plus (T, lhs, rhs) -> T (eval lhs + eval rhs)
    | `If (cond, lhs, rhs) -> (if eval cond then eval lhs else eval rhs)
;


let rec panic = fun x: any :: never -> panic x;

type ret[-In; +Out] = 
    | Raise In => Out 
    | RetNone opt[In] => Out 
    | Default (In => Out, Out)
;
let Raise = fun[T] _ :: ret[T;T] -> Raise id!;
let RetNone = fun[T] _ :: ret[T;opt[T]] -> RetNone id!;
let Default = fun[T] x: T :: ret[T;T] -> Default (id!, x);

let find = fun[In; Out] (x: In, style: ret[In; Out]) :: Out -> (
    if true then 
        match style with 
        | `Raise f -> f x
        | `RetNone f -> f Some x 
        | `Default (f, _) -> f x
    else 
        match style with 
        | `Raise -> panic "Element not found"
        | `RetNone f -> f None 
        | `Default (f, d) -> d 
);


type rec pipe[-In; +Out] = 
    | Step pipe_step[In; Out]
    | Empty In => Out 
and pipe_step[-In; +Out] = {type Mid; f: In -> Mid; rest: pipe[Mid; Out]}
; 
let Step = fun[In; Mid; Out] (f: (In -> Mid), rest: pipe[Mid; Out]) :: pipe[In; Out] -> (
    Step ({f; rest} :> pipe_step[_;_])
);
let Empty = fun[T] _ :: pipe[T; T] -> Empty id!;

let rec run = fun[In; Out] (v: In, fs: pipe[In; Out]) :: Out -> match fs with 
| `Step r -> (
    mod M: pipe_step[_;_] = r;
    run (M.f v, M.rest)
)
| `Empty f -> f v 
;

