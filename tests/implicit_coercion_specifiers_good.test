import test2{x};
print x.x + 1;

type T = {x: int};
let b = T {x=12};
let m = ((T$, b) :> {type B; _0: B => {x: int}; _1: B});
mod M implicit{B: _0 _} = m;
print M._1.x;


print (fun[C] implicit{C: Q _} (c: C, Q: (C => {x: int})) -> c.x) (b, T$);
